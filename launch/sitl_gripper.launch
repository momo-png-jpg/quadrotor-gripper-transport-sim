<?xml version="1.0"?>
<!--
  一键启动: PX4 SITL + Gazebo (带夹爪模型) + MAVROS
-->
<launch>

    <!-- ============================================================ -->
    <!-- 参数 -->
    <!-- ============================================================ -->
    <arg name="vehicle"     default="x500_gripper"/>
    <arg name="world"       default="$(find quadrotor_gripper_sim)/worlds/transport_world.world"/>
    <arg name="model_path"  default="$(find quadrotor_gripper_sim)/models"/>
    <arg name="fcu_url"     default="udp://:14540@127.0.0.1:14557"/>

    <!-- PX4 路径 -->
    <arg name="px4_dir"     default="$(env HOME)/PX4-Autopilot"/>

    <!-- ============================================================ -->
    <!-- 设置 Gazebo 模型路径 (让 Gazebo 找到我们的自定义模型) -->
    <!-- ============================================================ -->
    <env name="GAZEBO_MODEL_PATH"
         value="$(arg model_path):$(arg px4_dir)/Tools/simulation/gazebo-classic/sitl_gazebo-classic/models"/>
    <env name="GAZEBO_PLUGIN_PATH"
         value="$(arg px4_dir)/build/px4_sitl_default/build_gazebo-classic"/>
    <env name="GAZEBO_RESOURCE_PATH"
         value="/usr/share/gazebo-11"/>

    <!-- ============================================================ -->
    <!-- 1. 启动 Gazebo 服务器 + 客户端 -->
    <!-- ============================================================ -->
    <include file="$(find gazebo_ros)/launch/empty_world.launch">
        <arg name="world_name"  value="$(arg world)"/>
        <arg name="paused"      value="false"/>
        <arg name="gui"         value="true"/>
        <arg name="verbose"     value="true"/>
    </include>

    <!-- ============================================================ -->
    <!-- 2. 生成无人机模型到 Gazebo 中 -->
    <!-- ============================================================ -->
    <node name="spawn_model" pkg="gazebo_ros" type="spawn_model"
          args="-sdf
                -file $(arg model_path)/x500_gripper/model.sdf
                -model $(arg vehicle)
                -x 0 -y 0 -z 0.1"
          output="screen"/>

    <!-- ============================================================ -->
    <!-- 3. 启动 PX4 SITL -->
    <!-- ============================================================ -->
    <node name="px4_sitl" pkg="px4" type="px4"
          args="$(arg px4_dir)/build/px4_sitl_default/etc -s etc/init.d-posix/rcS"
          cwd="$(arg px4_dir)/build/px4_sitl_default"
          output="screen">
        <env name="PX4_SIM_MODEL" value="gazebo-classic_iris"/>
    </node>

    <!-- ============================================================ -->
    <!-- 4. 启动 MAVROS -->
    <!-- ============================================================ -->
    <include file="$(find mavros)/launch/px4.launch">
        <arg name="fcu_url" value="$(arg fcu_url)"/>
        <arg name="gcs_url" value=""/>
        <arg name="tgt_system" value="1"/>
        <arg name="tgt_component" value="1"/>
    </include>

</launch>
