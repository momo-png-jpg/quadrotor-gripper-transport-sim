<?xml version="1.0" ?>
<!--
  四旋翼 + 底部夹爪 + 负载
  基于 PX4 Iris 模型结构，适配 Gazebo Classic (SDF 1.6)
-->
<sdf version="1.6">
  <model name="x500_gripper">
    <pose>0 0 0.1 0 0 0</pose>

    <link name="base_link">
      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.029125</ixx>
          <iyy>0.029125</iyy>
          <izz>0.055225</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="body_collision">
        <geometry><box><size>0.15 0.15 0.05</size></box></geometry>
      </collision>
      <visual name="body_visual">
        <geometry><box><size>0.15 0.15 0.05</size></box></geometry>
        <material>
          <script>
            <uri>file://media/materials/scripts/gazebo.material</uri>
            <name>Gazebo/DarkGrey</name>
          </script>
        </material>
      </visual>

      <visual name="arm_fr">
        <pose>0.13 -0.13 0 0 0 -0.785</pose>
        <geometry><box><size>0.30 0.02 0.01</size></box></geometry>
        <material><script><name>Gazebo/Red</name>
          <uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
      <visual name="arm_fl">
        <pose>0.13 0.13 0 0 0 0.785</pose>
        <geometry><box><size>0.30 0.02 0.01</size></box></geometry>
        <material><script><name>Gazebo/Red</name>
          <uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
      <visual name="arm_rr">
        <pose>-0.13 -0.13 0 0 0 0.785</pose>
        <geometry><box><size>0.30 0.02 0.01</size></box></geometry>
        <material><script><name>Gazebo/Black</name>
          <uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
      <visual name="arm_rl">
        <pose>-0.13 0.13 0 0 0 -0.785</pose>
        <geometry><box><size>0.30 0.02 0.01</size></box></geometry>
        <material><script><name>Gazebo/Black</name>
          <uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>

      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>250</update_rate>
        <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
          <robotNamespace>/x500_gripper</robotNamespace>
          <topicName>imu</topicName>
          <frameName>base_link</frameName>
        </plugin>
      </sensor>
    </link>

    <link name="rotor_0">
      <pose>0.18 -0.18 0.03 0 0 0</pose>
      <inertial>
        <mass>0.025</mass>
        <inertia>
          <ixx>9.75e-6</ixx><iyy>1.66667e-4</iyy><izz>1.66667e-4</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="rotor_0_col">
        <geometry><cylinder><radius>0.128</radius><length>0.005</length></cylinder></geometry>
      </collision>
      <visual name="rotor_0_vis">
        <geometry><mesh><uri>model://iris/meshes/iris_prop_cw.dae</uri></mesh></geometry>
      </visual>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit></axis>
    </joint>
    <plugin name="rotor_0_model" filename="libgazebo_motor_model.so">
      <robotNamespace></robotNamespace>
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>0.000806428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <link name="rotor_1">
      <pose>-0.18 0.18 0.03 0 0 0</pose>
      <inertial>
        <mass>0.025</mass>
        <inertia>
          <ixx>9.75e-6</ixx><iyy>1.66667e-4</iyy><izz>1.66667e-4</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="rotor_1_vis">
        <geometry><mesh><uri>model://iris/meshes/iris_prop_cw.dae</uri></mesh></geometry>
      </visual>
    </link>
    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_1</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit></axis>
    </joint>
    <plugin name="rotor_1_model" filename="libgazebo_motor_model.so">
      <robotNamespace></robotNamespace>
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>0.000806428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <link name="rotor_2">
      <pose>0.18 0.18 0.03 0 0 0</pose>
      <inertial>
        <mass>0.025</mass>
        <inertia>
          <ixx>9.75e-6</ixx><iyy>1.66667e-4</iyy><izz>1.66667e-4</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="rotor_2_vis">
        <geometry><mesh><uri>model://iris/meshes/iris_prop_ccw.dae</uri></mesh></geometry>
      </visual>
    </link>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_2</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit></axis>
    </joint>
    <plugin name="rotor_2_model" filename="libgazebo_motor_model.so">
      <robotNamespace></robotNamespace>
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>0.000806428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <link name="rotor_3">
      <pose>-0.18 -0.18 0.03 0 0 0</pose>
      <inertial>
        <mass>0.025</mass>
        <inertia>
          <ixx>9.75e-6</ixx><iyy>1.66667e-4</iyy><izz>1.66667e-4</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="rotor_3_vis">
        <geometry><mesh><uri>model://iris/meshes/iris_prop_ccw.dae</uri></mesh></geometry>
      </visual>
    </link>
    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_3</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit></axis>
    </joint>
    <plugin name="rotor_3_model" filename="libgazebo_motor_model.so">
      <robotNamespace></robotNamespace>
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>3</motorNumber>
      <rotorDragCoefficient>0.000806428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <link name="gripper_base">
      <pose>0 0 -0.055 0 0 0</pose>
      <inertial>
        <mass>0.08</mass>
        <inertia>
          <ixx>1.5e-5</ixx><iyy>1.5e-5</iyy><izz>5e-6</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="gripper_rod">
        <geometry><cylinder><radius>0.008</radius><length>0.08</length></cylinder></geometry>
        <material><script><name>Gazebo/Grey</name>
          <uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
    </link>
    <joint name="gripper_base_joint" type="fixed">
      <parent>base_link</parent>
      <child>gripper_base</child>
    </joint>

    <link name="gripper_left">
      <pose>0 0.02 -0.10 0 0 0</pose>
      <inertial>
        <mass>0.025</mass>
        <inertia>
          <ixx>2e-6</ixx><iyy>5e-7</iyy><izz>2e-6</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="left_finger_vis">
        <geometry><box><size>0.008 0.004 0.05</size></box></geometry>
        <material><script><name>Gazebo/Orange</name>
          <uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
      <collision name="left_finger_col">
        <geometry><box><size>0.008 0.004 0.05</size></box></geometry>
      </collision>
    </link>
    <joint name="gripper_left_joint" type="revolute">
      <parent>gripper_base</parent>
      <child>gripper_left</child>
      <axis><xyz>1 0 0</xyz><limit><lower>-0.5</lower><upper>0.5</upper></limit></axis>
    </joint>

    <link name="gripper_right">
      <pose>0 -0.02 -0.10 0 0 0</pose>
      <inertial>
        <mass>0.025</mass>
        <inertia>
          <ixx>2e-6</ixx><iyy>5e-7</iyy><izz>2e-6</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="right_finger_vis">
        <geometry><box><size>0.008 0.004 0.05</size></box></geometry>
        <material><script><name>Gazebo/Orange</name>
          <uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
      <collision name="right_finger_col">
        <geometry><box><size>0.008 0.004 0.05</size></box></geometry>
      </collision>
    </link>
    <joint name="gripper_right_joint" type="revolute">
      <parent>gripper_base</parent>
      <child>gripper_right</child>
      <axis><xyz>1 0 0</xyz><limit><lower>-0.5</lower><upper>0.5</upper></limit></axis>
    </joint>

    <link name="payload">
      <pose>0 0 -0.155 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>2.08e-4</ixx><iyy>2.08e-4</iyy><izz>2.08e-4</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="payload_vis">
        <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
        <material><script><name>Gazebo/Green</name>
          <uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
      <collision name="payload_col">
        <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
      </collision>
    </link>
    <joint name="payload_joint" type="fixed">
      <parent>gripper_base</parent>
      <child>payload</child>
    </joint>

    <plugin name="mavlink_interface" filename="libgazebo_mavlink_interface.so">
      <robotNamespace></robotNamespace>
      <imuSubTopic>/imu</imuSubTopic>
      <mavlink_addr>INADDR_ANY</mavlink_addr>
      <mavlink_tcp_port>4560</mavlink_tcp_port>
      <mavlink_udp_port>14560</mavlink_udp_port>
      <serialEnabled>false</serialEnabled>
      <serialDevice>/dev/ttyACM0</serialDevice>
      <baudRate>921600</baudRate>
      <qgc_addr>INADDR_ANY</qgc_addr>
      <qgc_udp_port>14550</qgc_udp_port>
      <sdk_addr>INADDR_ANY</sdk_addr>
      <sdk_udp_port>14540</sdk_udp_port>
      <hil_mode>false</hil_mode>
      <hil_state_level>false</hil_state_level>
      <enable_lockstep>true</enable_lockstep>
      <use_tcp>true</use_tcp>
      <motorSpeedCommandPubTopic>/gazebo/command/motor_speed</motorSpeedCommandPubTopic>
      <control_channels>
        <channel name="rotor0"><input_index>0</input_index><input_offset>0</input_offset>
          <input_scaling>1100</input_scaling><zero_position_disarmed>0</zero_position_disarmed>
          <zero_position_armed>100</zero_position_armed><joint_control_type>velocity</joint_control_type></channel>
        <channel name="rotor1"><input_index>1</input_index><input_offset>0</input_offset>
          <input_scaling>1100</input_scaling><zero_position_disarmed>0</zero_position_disarmed>
          <zero_position_armed>100</zero_position_armed><joint_control_type>velocity</joint_control_type></channel>
        <channel name="rotor2"><input_index>2</input_index><input_offset>0</input_offset>
          <input_scaling>1100</input_scaling><zero_position_disarmed>0</zero_position_disarmed>
          <zero_position_armed>100</zero_position_armed><joint_control_type>velocity</joint_control_type></channel>
        <channel name="rotor3"><input_index>3</input_index><input_offset>0</input_offset>
          <input_scaling>1100</input_scaling><zero_position_disarmed>0</zero_position_disarmed>
          <zero_position_armed>100</zero_position_armed><joint_control_type>velocity</joint_control_type></channel>
      </control_channels>
    </plugin>

  </model>
</sdf>